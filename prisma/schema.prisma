
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String
  createdAt DateTime @default(now())
}

model Client {
  id        String   @id @default(cuid())
  name      String
  cpf       String
  phone     String
  createdAt DateTime @default(now())
}

model Loan {
  id            String   @id @default(cuid())
  amount        Float
  interest      Float
  installments  Int
  clientId      String
  createdAt     DateTime @default(now())
}
